# ============================================
# UKP2SA Environment Configuration
# Copy this file to .env and fill in the values
# ============================================

# App Mode
NEXT_PUBLIC_API_MODE=production
NEXT_PUBLIC_API_URL=https://your-domain.id

# Supabase (Get from: supabase.com/dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_publishable_key_here

# External APIs — Diswatch
BANJIR_SUMATRA_API=https://diswatchapi.tilikan.id/api/v1
NEXT_PUBLIC_BANJIR_SUMATRA_API=https://diswatchapi.tilikan.id/api/v1

# External APIs — Banjir Sumatra Public
BANJIR_SUMATRA_PUBLIC_API=https://api.banjirsumatra.id/api/v1
NEXT_PUBLIC_BANJIR_SUMATRA_PUBLIC_API=https://api.banjirsumatra.id/api/v1

# External APIs — SuperDash / Tilikan
SUPERDASH_API=https://superdashapi.tilikan.id/api/v1
NEXT_PUBLIC_SUPERDASH_API=https://superdashapi.tilikan.id/api/v1

# Midtrans Payment Gateway
NEXT_PUBLIC_MIDTRANS_IS_PRODUCTION=false
MIDTRANS_SERVER_KEY=your_midtrans_server_key
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=your_midtrans_client_key

# Auth.js / NextAuth v5
AUTH_SECRET=generate_with_openssl_rand_hex_32
AUTH_URL=https://your-domain.id/api/auth
NEXTAUTH_URL=https://your-domain.id
AUTH_TRUST_HOST=true

# PII Encryption Key (AES-256, 64 hex chars)
ENCRYPTION_KEY=generate_64_hex_chars_here

# JWT Config
JWT_SECRET=generate_64_hex_chars_here
JWT_EXPIRES_IN=8h
JWT_COOKIE_EXPIRES_IN=8

# Cloudflare R2 Storage
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_BUCKET_NAME=your_bucket_name
R2_CDN_DOMAIN=https://cdn.your-domain.id

# SMTP Email
SMTP_HOST=mail.your-domain.id
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@your-domain.id
SMTP_PASS=your_smtp_password
SMTP_FROM="App Name <noreply@your-domain.id>"

# Sync Key (Cron Job Authentication)
SYNC_KEY=generate_random_string_here
