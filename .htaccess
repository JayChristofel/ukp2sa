# ============================================================
# UKP2SA Security .htaccess — Pentest Remediation v3
# ============================================================

# --- Enable Apache mod_rewrite ---
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Host Header Injection → Handled by Cloudflare + proxy.ts (not here)
    # cPanel Passenger modifies Host header internally, so .htaccess check breaks things

    # --- OPEN REDIRECT PROTECTION ---
    # Block redirect ke external domain via query string
    RewriteCond %{QUERY_STRING} (^|&)(url|redirect|next|return|returnTo|goto|destination|redir|out)=https?:// [NC,OR]
    RewriteCond %{QUERY_STRING} (^|&)(url|redirect|next|return|returnTo|goto|destination|redir|out)=// [NC]
    RewriteRule ^ - [F,L]
</IfModule>

# ============================================================
# SECURITY HEADERS — Ini yang dibaca pentest scanner
# ============================================================
<IfModule mod_headers.c>
    # --- Strip server tech disclosure ---
    Header always unset x-turbo-charged-by
    Header always unset X-Powered-By
    Header always unset Server

    # --- HSTS: Force HTTPS for all connections ---
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # --- Prevent Clickjacking ---
    Header always set X-Frame-Options "DENY"

    # --- Prevent MIME-type sniffing ---
    Header always set X-Content-Type-Options "nosniff"

    # --- XSS Protection (legacy browsers) ---
    Header always set X-XSS-Protection "1; mode=block"

    # --- Referrer Policy ---
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # --- Permissions Policy ---
    Header always set Permissions-Policy "camera=(self), microphone=(), geolocation=(self), interest-cohort=()"

    # --- Content Security Policy (FIXED: No wildcard, No unsafe-eval) ---
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.google-analytics.com https://static.cloudflareinsights.com blob:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob: https://*.supabase.co https://*.tile.openstreetmap.org https://*.arcgisonline.com https://*.basemaps.cartocdn.com https://*.dicebear.com https://fonts.gstatic.com https://www.google-analytics.com https://static.cloudflareinsights.com https://*.google.com https://*.googleusercontent.com https://www.transparenttextures.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://*.supabase.co https://api.open-meteo.com https://*.tilikan.id https://api.banjirsumatra.id https://www.google-analytics.com https://static.cloudflareinsights.com; frame-ancestors 'none'; object-src 'none'; base-uri 'self'; form-action 'self';"

    # --- DNS Prefetch Control ---
    Header always set X-DNS-Prefetch-Control "off"

    # --- Cross-Origin headers ---
    Header always set Cross-Origin-Opener-Policy "same-origin"
    Header always set Cross-Origin-Resource-Policy "same-origin"
    Header always set Cross-Origin-Embedder-Policy "credentialless"

    # --- Cache Control untuk halaman HTML (bukan static assets) ---
    <FilesMatch "\.(html|htm|php)$">
        Header always set Cache-Control "no-store, no-cache, must-revalidate, proxy-revalidate"
        Header always set Pragma "no-cache"
    </FilesMatch>
</IfModule>

# ============================================================
# FILE ACCESS PROTECTION
# ============================================================

# --- VULN-007: Block backup/archive files ---
<FilesMatch "\.(zip|tar|gz|bz2|7z|rar|bak|sql|dump|old|swp|sav)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# --- VULN-008: Block .git, .env, and other sensitive dotfiles ---
<DirectoryMatch "^(.*/)?\.(git|svn|hg)">
    Order allow,deny
    Deny from all
</DirectoryMatch>

<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block known sensitive files explicitly
<FilesMatch "(\.env|\.git|\.gitignore|\.htpasswd|composer\.json|composer\.lock|package\.json|package-lock\.json|yarn\.lock|tsconfig\.json|next\.config\.(js|ts|mjs))$">
    Order allow,deny
    Deny from all
</FilesMatch>

# --- Block source code files from direct access ---
<FilesMatch "\.(ts|tsx|jsx|mjs|map)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# ============================================================
# CMS PROBING & MISC PROTECTION
# ============================================================

# --- Block common CMS/config probing paths ---
RedirectMatch 404 /wp-admin
RedirectMatch 404 /wp-login
RedirectMatch 404 /wp-content
RedirectMatch 404 /xmlrpc.php
RedirectMatch 404 /phpmyadmin

# --- Prevent directory listing ---
Options -Indexes

# --- Disable server signature ---
ServerSignature Off
